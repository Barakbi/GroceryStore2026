# ====================
# PRODUCTION ENVIRONMENT VARIABLES
# ====================
# This is a template for production environment variables
# DO NOT commit actual production values to git
# Copy values to Railway/Vercel dashboards

# ====================
# RAILWAY (Backend)
# ====================
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"
JWT_SECRET="GENERATE-A-SECURE-RANDOM-32-CHARACTER-STRING-HERE"
JWT_EXPIRES_IN="7d"
PORT=3000
NODE_ENV="production"
FRONTEND_URL="https://your-app.vercel.app"

# ====================
# VERCEL (Frontend)
# ====================
# Add this in Vercel dashboard → Settings → Environment Variables
VITE_API_URL="https://your-backend.up.railway.app/api"

# ====================
# HOW TO GENERATE SECURE JWT_SECRET
# ====================
# Run this command in your terminal:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# Or use an online generator:
#   https://generate-secret.vercel.app/32
